  "hierarchy": [
    {
      "rank": 1,
      "mark": "Main logo — Gradient",
      "status": "primary",
      "use_when": [
        "default choice",
        "website, marketing, ads, decks, social",
        "anywhere the brand is the star"
      ],
      "never": [
        "small sizes where the gradient muddies"
      ]
    },
    {
      "rank": 2,
      "mark": "Main logo — Flat",
      "status": "secondary",
      "use_when": [
        "small sizes",
        "limited colours (one-colour print, embroidery, engraving)",
        "busy backgrounds"
      ],
      "never": [
        "as a style preference when the gradient would work"
      ]
    },
    {
      "rank": 3,
      "mark": "M letterform (Bracket M)",
      "status": "restricted",
      "use_when": [
        "merch (tees, caps, stickers, totes)",
        "in-app animation (loading states, motion moments)",
        "favicon"
      ],
      "never": [
        "marketing materials",
        "as a wordmark replacement"
      ]
    },
    {
      "rank": 4,
      "mark": "Monogram (M in pill)",
      "status": "restricted",
      "use_when": [
        "merch (pins, embroidery, small details)",
        "small scale (name cards, tiny print)",
        "watermarks"
      ],
      "never": [
        "as the main logo",
        "as the app icon"
      ]
    }
  ],
  "decision_checklist": [
    "Marketing, deck, website, anything public-facing → Main logo, Gradient",
    "Small, one-colour, or busy background → Main logo, Flat",
    "Merch or in-app animation → M letterform (monogram also fine on merch)",
    "Name card, watermark, or tiny space → Monogram",
    "Unsure → Main logo, Gradient — or ask the design team"
  ]
}